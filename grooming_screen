    '',
    '    showConfirm(confirmMsg, () => {',
    '      if(actionType === \'save\' || actionType === \'backlog\' || actionType === \'worklist\' || (actionType === \'complete\' && currentStatusMode === \'maturity\') || (actionType === \'complete\' && currentStatusMode === \'control\' && isUrgentRequestChecked())){',
    '        fetch(UPDATE, {',
    '          method: \'POST\',',
