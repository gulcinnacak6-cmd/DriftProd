    '      result.name = text.substring(0, opinionOnlyMatch.index).trim();',
    '      result.opinion = text.substring(opinionOnlyMatch.index + opinionOnlyMatch[0].length).trim();',
    '      return result;',
    '    }',
    '    const splitIdx = text.indexOf(":");',
    '    if(splitIdx !== -1){',
    '      result.name = text.substring(0, splitIdx).trim();',
    '      result.opinion = text.substring(splitIdx + 1).trim();',
    '    } else {',
    '      result.name = text;',
    '    }',
    '    return result;',
    '  }',
    '',
    '  function parseExistingUnits(text){',
