import com.onresolve.scriptrunner.runner.rest.common.CustomEndpointDelegate
import groovy.transform.BaseScript

import javax.ws.rs.core.MultivaluedMap
import javax.ws.rs.core.Response

@BaseScript CustomEndpointDelegate delegate

navigationHub(httpMethod: "GET") { MultivaluedMap queryParams ->

    def html = """
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Filozof Hub</title>
<script>
(function(){
    var hubPath = window.location.pathname + window.location.search + window.location.hash;
    var loginUrl = '/jira/login.jsp?os_destination=' + encodeURIComponent(hubPath);
    var sessionUrl = '/jira/rest/auth/1/session';
    var myselfUrl = '/jira/rest/api/2/myself?expand=groups';
    var searchUrl = '/jira/rest/scriptrunner/latest/custom/olgunlastirmaSearch?pool=idea&scope=all';
    var portfolioSearchUrl = '/jira/rest/scriptrunner/latest/custom/olgunlastirmaSearch?pool=request&role=pmo&scope=myportfolio';
    var serverLogoUrl = '/jira/rest/scriptrunner/latest/custom/navigationHubAsset?type=logo';
    var logoIssueUrl = '/jira/rest/api/2/issue/P16-4768?fields=attachment';
    var logoFileName = 'fi.png';
    var serverVideoUrl = '/jira/rest/scriptrunner/latest/custom/navigationHubAsset?type=video';
    var videoIssueUrl = '/jira/rest/api/2/issue/P16-4768?fields=attachment';
    var videoFileName = '';
    var introVideoSrc = '';
    var introVideoLoading = false;
    var assetVersion = new Date().getTime().toString();

    function whenDomReady(callback){
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', callback);
        } else {
            callback();
        }
    }

    function goLogin(){
        if (window.location.pathname.indexOf('/login.jsp') === -1) {
            window.location.replace(loginUrl);
        }
    }

    function withAssetVersion(url){
        if (!url) return '';
        return url + (url.indexOf('?') === -1 ? '?' : '&') + 'v=' + encodeURIComponent(assetVersion);
    }

    function initials(name){
        var parts = (name || '').trim().split(/\\s+/).filter(Boolean);
        if (!parts.length) return '?';
        return ((parts[0] || '').charAt(0) + (parts.length > 1 ? (parts[parts.length - 1] || '').charAt(0) : '')).toUpperCase();
    }

    function renderUserProfile(user){
        var profile = document.getElementById('userProfile');
        if (!profile || !user) return;

        var displayName = user.displayName || user.name || user.key || 'Kullanıcı';
        var userKey = user.name || user.key || '';
        var avatarUrls = user.avatarUrls || {};
        var avatarUrl = avatarUrls['48x48'] || avatarUrls['32x32'] || avatarUrls['24x24'] || avatarUrls['16x16'] || '';
        var profileUrl = userKey ? ('/jira/secure/ViewProfile.jspa?name=' + encodeURIComponent(userKey)) : '/jira/secure/ViewProfile.jspa';
        var avatarEl = profile.querySelector('.user-avatar');
        var nameEl = profile.querySelector('.user-name');
        var metaEl = profile.querySelector('.user-meta');

        profile.href = profileUrl;
        profile.title = displayName + ' profilini görüntüle';
        if (nameEl) nameEl.textContent = displayName;
        if (metaEl) metaEl.textContent = userKey || 'Profil';
        if (avatarEl) {
            if (avatarUrl) {
                avatarEl.textContent = '';
                avatarEl.style.backgroundImage = 'url("' + avatarUrl.replace(/"/g, '%22') + '")';
                avatarEl.classList.add('image');
            } else {
                avatarEl.textContent = initials(displayName);
            }
        }
    }

    function normalizeText(value){
        return (value || '').toString().trim().toLocaleLowerCase('tr-TR');
    }

    function foldText(value){
        var text = normalizeText(value);
        try {
            text = text.normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');
        } catch (e) {}
        return text.replace(/ı/g, 'i');
    }

    function resolveAttachmentUrl(attachment){
        if (!attachment) return '';
        if (attachment.content) return attachment.content;
        if (attachment.id && attachment.filename) {
            return '/jira/secure/attachment/' + encodeURIComponent(attachment.id) + '/' + encodeURIComponent(attachment.filename);
        }
        return '';
    }

    function setFilozofLogo(src){
        if (!src) return;
        whenDomReady(function(){
            var logos = document.querySelectorAll('[data-logo-target]');
            Array.prototype.forEach.call(logos, function(logo){
                logo.onload = function(){
                    logo.classList.add('logo-loaded');
                    if (logo.parentNode) logo.parentNode.classList.add('has-logo');
                };
                logo.onerror = function(){
                    logo.classList.remove('logo-loaded');
                    if (logo.parentNode) logo.parentNode.classList.remove('has-logo');
                };
                logo.src = src;
            });
        });
    }

    function loadFilozofLogo(){
        fetch(logoIssueUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (response.status !== 200 || contentType.indexOf('application/json') === -1) return null;
                return response.json();
            })
            .then(function(data){
                var attachments = data && data.fields && Array.isArray(data.fields.attachment) ? data.fields.attachment : [];
                var targetName = foldText(logoFileName);
                var match = attachments.filter(function(attachment){
                    return foldText(attachment.filename) === targetName;
                })[0] || attachments.filter(function(attachment){
                    return (attachment.mimeType || '').indexOf('image/') === 0;
                })[0];
                setFilozofLogo(resolveAttachmentUrl(match));
            })
            .catch(function(){});
    }

    function loadServerLogo(){
        if (!serverLogoUrl) {
            loadFilozofLogo();
            return;
        }
        if (!window.fetch || !window.URL || !window.URL.createObjectURL) {
            setFilozofLogo(withAssetVersion(serverLogoUrl));
            return;
        }
        fetch(withAssetVersion(serverLogoUrl), { credentials: 'same-origin', headers: { 'Accept': '*/*' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (!response || response.status !== 200 || contentType.indexOf('image/') !== 0) {
                    throw new Error('server-logo');
                }
                return response.blob();
            })
            .then(function(blob){
                setFilozofLogo(window.URL.createObjectURL(blob));
            })
            .catch(function(){
                loadFilozofLogo();
            });
    }

    function isVideoAttachment(attachment){
        var mime = normalizeText(attachment && attachment.mimeType);
        var name = attachment && attachment.filename ? attachment.filename : '';
        return mime.indexOf('video/') === 0 || /\\.(mp4|m4v|mov|webm)\$/i.test(name);
    }

    function pickVideoAttachment(attachments){
        var items = Array.isArray(attachments) ? attachments : [];
        var targetName = foldText(videoFileName);
        if (targetName) {
            var named = items.filter(function(attachment){
                return foldText(attachment.filename) === targetName;
            })[0];
            if (named) return named;
        }
        return items.filter(isVideoAttachment)[0] || null;
    }

    function setIntroVideoStatus(message, isError){
        whenDomReady(function(){
            var status = document.getElementById('introVideoStatus');
            if (!status) return;
            status.textContent = message || '';
            status.classList.toggle('is-error', !!isError);
        });
    }

    function readResponseText(response){
        if (!response || !response.text) return Promise.resolve('');
        return response.text()
            .then(function(text){
                return (text || '').replace(/\\s+/g, ' ').trim().slice(0, 260);
            })
            .catch(function(){
                return '';
            });
    }

    function assetProbeUrl(src){
        if (!src) return '';
        return src + (src.indexOf('?') === -1 ? '?' : '&') + 'probe=1';
    }

    function validateVideoAsset(src){
        if (!window.fetch) return Promise.resolve(src);
        return fetch(assetProbeUrl(src), { credentials: 'same-origin', headers: { 'Accept': '*/*' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                var status = response ? response.status : 'yok';
                if (!response || response.status !== 200 || contentType.indexOf('application/json') === -1) {
                    return readResponseText(response).then(function(text){
                        throw new Error('Video endpoint hatasi: status=' + status + ', type=' + (contentType || '-') + (text ? ', body=' + text : ''));
                    });
                }
                return response.json().then(function(data){
                    var mimeType = data && data.mimeType ? data.mimeType : '';
                    var length = data && data.length ? Number(data.length) : 0;
                    if (data && data.success === true && mimeType.indexOf('video/') === 0 && length > 0) return src;
                    var detail = '';
                    try {
                        detail = JSON.stringify(data || {}).slice(0, 260);
                    } catch (e) {}
                    throw new Error('Video endpoint hatasi: status=' + status + ', type=' + (contentType || '-') + (detail ? ', body=' + detail : ''));
                });
            })
            .catch(function(error){
                if (error && error.message && error.message.indexOf('Video endpoint hatasi:') === 0) throw error;
                throw new Error('Video endpoint istegi basarisiz: ' + ((error && error.message) ? error.message : 'bilinmeyen hata'));
            });
    }

    function isIntroVideoOpen(){
        var modal = document.getElementById('introVideoModal');
        return !!(modal && modal.getAttribute('aria-hidden') === 'false');
    }

    function setIntroVideoPlayerSource(src){
        if (!src) return;
        introVideoSrc = src;
        whenDomReady(function(){
            var player = document.getElementById('introVideoPlayer');
            if (!player) return;
            if (!isIntroVideoOpen()) return;
            player.onerror = function(){
                introVideoLoading = false;
                var code = player.error ? player.error.code : '-';
                setIntroVideoStatus('Video player oynatamadi. errorCode=' + code + ', endpoint=' + src, true);
            };
            player.onloadedmetadata = function(){
                introVideoLoading = false;
                setIntroVideoStatus('', false);
            };
            if (player.getAttribute('src') !== src) {
                setIntroVideoStatus('Video yukleniyor...', false);
                player.src = src;
                player.load();
            }
        });
    }

    function resolveIntroVideoSrc(){
        if (introVideoSrc) return Promise.resolve(introVideoSrc);
        if (serverVideoUrl) {
            var src = withAssetVersion(serverVideoUrl);
            return validateVideoAsset(src).then(function(validSrc){
                setIntroVideoPlayerSource(validSrc);
                return validSrc;
            });
        }
        if (!window.fetch || !videoIssueUrl) {
            return Promise.reject(new Error('video-source'));
        }
        return fetch(videoIssueUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (response.status !== 200 || contentType.indexOf('application/json') === -1) throw new Error('video-issue');
                return response.json();
            })
            .then(function(data){
                var attachments = data && data.fields && Array.isArray(data.fields.attachment) ? data.fields.attachment : [];
                var match = pickVideoAttachment(attachments);
                var src = resolveAttachmentUrl(match);
                if (!src) throw new Error('video-attachment');
                setIntroVideoPlayerSource(src);
                return src;
            });
    }

    function ensureIntroVideoLoaded(){
        if (introVideoLoading) return;
        introVideoLoading = true;
        setIntroVideoStatus('Video hazırlanıyor...', false);
        resolveIntroVideoSrc()
            .then(function(src){
                setIntroVideoPlayerSource(src);
            })
            .catch(function(error){
                setIntroVideoStatus((error && error.message) ? error.message : 'Video dosyasi bulunamadi veya erisim izni yok.', true);
            })
            .then(function(){
                introVideoLoading = false;
            });
    }

    function stopIntroVideo(){
        var player = document.getElementById('introVideoPlayer');
        if (!player) return;
        try {
            player.pause();
        } catch (e) {}
        player.removeAttribute('src');
        player.load();
    }

    window.openIntroVideo = function(){
        whenDomReady(function(){
            var modal = document.getElementById('introVideoModal');
            if (!modal) return;
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('video-modal-open');
            ensureIntroVideoLoaded();
        });
    };

    window.closeIntroVideo = function(){
        whenDomReady(function(){
            var modal = document.getElementById('introVideoModal');
            if (modal) {
                modal.style.display = 'none';
                modal.setAttribute('aria-hidden', 'true');
            }
            document.body.classList.remove('video-modal-open');
            stopIntroVideo();
        });
    };

    whenDomReady(function(){
        document.addEventListener('keydown', function(event){
            if (event.key === 'Escape') window.closeIntroVideo();
        });
    });

    function collectGroupNames(user){
        if (!user || !user.groups) return [];
        var groups = user.groups;
        var items = [];
        if (Array.isArray(groups)) {
            items = groups;
        } else if (Array.isArray(groups.items)) {
            items = groups.items;
        } else if (Array.isArray(groups.values)) {
            items = groups.values;
        } else if (Array.isArray(groups.groups)) {
            items = groups.groups;
        }
        return items.map(function(group){
            if (typeof group === 'string') return group;
            return group.name || group.displayName || group.groupName || '';
        }).filter(Boolean);
    }

    function sameGroup(actual, expected){
        var left = foldText(actual);
        var right = foldText(expected);
        return left === right || left.replace(/\\s+/g, '') === right.replace(/\\s+/g, '');
    }

    function hasAnyGroup(groupNames, candidates){
        return groupNames.some(function(groupName){
            return candidates.some(function(candidate){
                return sameGroup(groupName, candidate);
            });
        });
    }

    function activeRolesForUser(user){
        var groupNames = collectGroupNames(user);
        if (!groupNames.length) return ['business', 'pmo', 'it'];
        if (hasAnyGroup(groupNames, ['jira-administrators'])) return ['business', 'pmo', 'it'];

        var roles = [];
        if (hasAnyGroup(groupNames, ['AtlasBt', 'FibaBt'])) roles.push('it');
        if (hasAnyGroup(groupNames, ['AtlasisBirimi', 'Atlas İş Birimi', 'Atlas Is Birimi'])) roles.push('business');
        if (hasAnyGroup(groupNames, ['Proje ve Portföy Yönetimi Ofisi', 'Proje ve Portfoy Yonetimi Ofisi', 'PMO'])) roles.push('pmo');
        return roles;
    }

    function setRoleSectionState(section, active){
        section.classList.toggle('role-active', active);
        section.classList.toggle('role-inactive', !active);
        section.setAttribute('aria-disabled', active ? 'false' : 'true');
        var cards = section.querySelectorAll('.card');
        Array.prototype.forEach.call(cards, function(card){
            card.setAttribute('aria-disabled', active ? 'false' : 'true');
            card.title = active ? '' : 'Bu bölüm rolünüz için pasif';
        });
    }

    function applyRoleAccess(user){
        var roles = activeRolesForUser(user);
        var roleNames = ['business', 'pmo', 'it'];
        roleNames.forEach(function(roleName){
            var active = roles.indexOf(roleName) !== -1;
            var sections = document.querySelectorAll('[data-role-section="' + roleName + '"]');
            Array.prototype.forEach.call(sections, function(section){
                setRoleSectionState(section, active);
            });
        });
    }

    function statusMode(status){
        var v = normalizeText(status);
        if (v.indexOf('olgunluk kontrol') !== -1 || v.indexOf('olg. kont') !== -1) return 'control';
        if (v.indexOf('olgunlaştırma') !== -1 || v.indexOf('olgunlastirma') !== -1) return 'maturity';
        if (v.indexOf('önceliklendirme') !== -1 || v.indexOf('onceliklendirme') !== -1) return 'prioritization';
        if (v.indexOf('backlog') !== -1 || v.indexOf('talebe dönüştürüldü') !== -1 || v.indexOf('talebe donusturuldu') !== -1) return 'backlog';
        if (v.indexOf('iş list') !== -1 || v.indexOf('is list') !== -1) return 'worklist';
        return 'other';
    }

    function hasValue(value){
        var text = (value || '').toString().trim();
        return text !== '' && text !== '-';
    }

    function userTokens(user){
        if (!user) return [];
        return [user.key, user.name, user.displayName]
            .map(normalizeText)
            .filter(Boolean);
    }

    function isCurrentUserIssue(issue, user){
        var mineTokens = userTokens(user);
        if (!mineTokens.length || !issue) return false;
        var reporterTokens = [issue.reporterKey, issue.reporterName, issue.reporter]
            .map(normalizeText)
            .filter(Boolean);
        return reporterTokens.some(function(token){ return mineTokens.indexOf(token) !== -1; });
    }

    function extractGGroupCodes(values){
        var items = Array.isArray(values) ? values : [values];
        var codes = [];
        items.forEach(function(value){
            var text = (value || '').toString();
            var matches = text.match(/\\bG\\d+\\b/gi) || [];
            matches.forEach(function(code){
                var normalized = code.toUpperCase();
                if (codes.indexOf(normalized) === -1) codes.push(normalized);
            });
        });
        return codes;
    }

    function fieldMatchesCurrentGroups(fieldValue, user){
        var userGroups = collectGroupNames(user);
        var fieldText = (fieldValue || '').toString();
        if (!fieldText || fieldText === '-') return false;
        var normalizedField = foldText(fieldText);
        var directMatch = userGroups.some(function(groupName){
            var normalizedGroup = foldText(groupName);
            return normalizedField === normalizedGroup || normalizedField.indexOf(normalizedGroup) !== -1 || normalizedGroup.indexOf(normalizedField) !== -1;
        });
        if (directMatch) return true;
        var userCodes = extractGGroupCodes(userGroups);
        var fieldCodes = extractGGroupCodes(fieldText);
        return userCodes.some(function(code){ return fieldCodes.indexOf(code) !== -1; });
    }

    function isPortfolioMineOrEmpty(issue, user){
        if (!issue) return false;
        if (!hasValue(issue.portfoy)) return true;
        var portfoyToken = normalizeText(issue.portfoy);
        return userTokens(user).some(function(token){ return token && (portfoyToken === token || portfoyToken.indexOf(token) !== -1); });
    }

    function parseIssueDate(value){
        var text = (value || '').toString().trim();
        if (!text || text === '-') return null;
        var parsed = Date.parse(text.replace(' ', 'T'));
        return isNaN(parsed) ? null : new Date(parsed);
    }

    function isWithinDays(value, days){
        var date = parseIssueDate(value);
        if (!date) return false;
        var now = new Date();
        var end = new Date(now.getTime() + (days * 24 * 60 * 60 * 1000));
        return date >= now && date <= end;
    }

    function setText(id, value){
        var el = document.getElementById(id);
        if (el) el.textContent = value;
    }

    function setCount(id, value){
        setText(id, (typeof value === 'number' && isFinite(value)) ? value.toString() : '-');
    }

    function renderHubMetrics(issues, user){
        var stats = {
            total: issues.length,
            mine: 0,
            mineControl: 0,
            control: 0,
            maturity: 0,
            prioritization: 0,
            backlog: 0,
            worklist: 0,
            converted: 0,
            portfolioMineOrEmpty: 0,
            teamIdeas: 0,
            responsibleIdeas: 0,
            pmoOpen: 0,
            pmoMissingOwner: 0,
            meetingSoon: 0,
            itOpen: 0,
            itNeedsScore: 0
        };

        issues.forEach(function(issue){
            var mode = statusMode(issue.status);
            var mine = isCurrentUserIssue(issue, user);
            var converted = hasValue(issue.filozofConvertedRequest);
            if (mine) stats.mine += 1;
            if (mine && mode === 'control') stats.mineControl += 1;
            if (mode === 'control') stats.control += 1;
            if (mode === 'maturity') stats.maturity += 1;
            if (mode === 'prioritization') stats.prioritization += 1;
            if (mode === 'backlog') stats.backlog += 1;
            if (mode === 'worklist') stats.worklist += 1;
            if (converted) stats.converted += 1;
            if (converted && isPortfolioMineOrEmpty(issue, user)) stats.portfolioMineOrEmpty += 1;
            if (fieldMatchesCurrentGroups(issue.businessAuthGroup, user)) stats.teamIdeas += 1;
            if (fieldMatchesCurrentGroups(issue.anaSorumluGrup, user)) stats.responsibleIdeas += 1;
            if (mode === 'control' || mode === 'maturity' || mode === 'prioritization') stats.pmoOpen += 1;
            if ((mode === 'control' || mode === 'maturity' || mode === 'prioritization') && !hasValue(issue.portfoy)) stats.pmoMissingOwner += 1;
            if (isWithinDays(issue.meetingDate, 7)) stats.meetingSoon += 1;
            if (mode === 'maturity') stats.itOpen += 1;
            if (mode === 'maturity' && (!hasValue(issue.itScore) || !hasValue(issue.anaSorumluBirim))) stats.itNeedsScore += 1;
        });

        setCount('badgeBusinessIdeaPool', stats.total);
        setCount('badgeBusinessMaturity', stats.maturity);
        setCount('badgeBusinessBacklog', stats.backlog);
        setCount('badgeBusinessPlanned', stats.worklist);
        setCount('badgePmoControl', stats.control);
        setCount('badgePmoMaturity', stats.maturity);
        setCount('badgePmoIdeaPool', stats.total);
        setCount('badgePmoBacklog', stats.backlog);
        setCount('badgePmoPlanned', stats.worklist);
        setCount('badgeItMaturity', stats.maturity);
        setCount('badgeItIdeaPool', stats.total);
        setCount('badgeItBacklog', stats.backlog);
        setCount('badgeItPlanned', stats.worklist);
    }

    function loadHubMetrics(user){
        fetch(searchUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (response.status !== 200 || contentType.indexOf('application/json') === -1) throw new Error('metrics');
                return response.json();
            })
            .then(function(data){
                renderHubMetrics(data.issues || [], user || data.currentUser || {});
            })
            .catch(function(){});
    }

    function loadPortfolioMetrics(){
        fetch(portfolioSearchUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (response.status !== 200 || contentType.indexOf('application/json') === -1) throw new Error('portfolioMetrics');
                return response.json();
            })
            .then(function(data){
                setCount('badgePmoPortfolio', (data.issues || []).length);
            })
            .catch(function(){});
    }

    function loadUserProfile(){
        fetch(myselfUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function(response){
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (response.status !== 200 || contentType.indexOf('application/json') === -1) return null;
                return response.json();
            })
            .then(function(user){
                whenDomReady(function(){
                    renderUserProfile(user);
                    applyRoleAccess(user);
                    loadHubMetrics(user);
                    loadPortfolioMetrics();
                });
            })
            .catch(function(){
                whenDomReady(function(){
                    applyRoleAccess(null);
                    loadHubMetrics(null);
                    loadPortfolioMetrics();
                });
            });
    }

    if (window.fetch) {
        fetch(sessionUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function(response){
                var url = response && response.url ? response.url : '';
                var contentType = response && response.headers ? (response.headers.get('content-type') || '') : '';
                if (response.status !== 200 || contentType.indexOf('application/json') === -1 || (response.redirected && url.indexOf('/login.jsp') !== -1) || url.indexOf('/login.jsp') !== -1) {
                    goLogin();
                    return;
                }
                loadServerLogo();
                loadUserProfile();
            })
            .catch(function(){ goLogin(); });
    } else {
        goLogin();
    }
})();
</script>

<style>
body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial;
    background: #F4F5F7;
    color: #172B4D;
    position: relative;
}

