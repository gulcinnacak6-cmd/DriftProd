    type == "logo" ? NAV_LOGO_FILE_NAME : (type == "video" ? NAV_VIDEO_FILE_NAME : "")
}

def navMimeType = { String filename ->
    def lower = (filename ?: "").toLowerCase(Locale.ENGLISH)
    if (lower.endsWith(".png")) return "image/png"
    if (lower.endsWith(".jpg") || lower.endsWith(".jpeg")) return "image/jpeg"
    if (lower.endsWith(".gif")) return "image/gif"
    if (lower.endsWith(".webp")) return "image/webp"
    if (lower.endsWith(".mp4") || lower.endsWith(".m4v")) return "video/mp4"
    if (lower.endsWith(".mov")) return "video/quicktime"
    if (lower.endsWith(".webm")) return "video/webm"
    "application/octet-stream"
}

def navAttachmentFile = { attachment, String expectedFilename ->
    def errors = []

    try {
        def directFile = attachmentManager.getAttachmentFile(attachment)
        if (directFile) {
            return [file: directFile, error: ""]
        }
        errors << "getAttachmentFile null dondu"
    } catch (Exception ex) {
        errors << "getAttachmentFile: ${ex.class.simpleName}: ${ex.message}"
    }

    try {
        def attachmentId = attachment?.id?.toString() ?: "unknown"
        def safeFilename = (expectedFilename ?: "asset.bin").replaceAll("[^A-Za-z0-9._-]", "_")
        def cacheDir = new File(System.getProperty("java.io.tmpdir"), "filozof-navigation-assets")
        if (!cacheDir.exists() && !cacheDir.mkdirs()) {
            return [file: null, error: (errors + "cache klasoru olusturulamadi: ${cacheDir.absolutePath}").join(" | ")]
        }

        def cacheFile = new File(cacheDir, "${attachmentId}-${safeFilename}")
        if (cacheFile.exists() && cacheFile.length() > 0L) {
            return [file: cacheFile, error: ""]
        }

        def tmpFile = new File(cacheDir, "${attachmentId}-${safeFilename}.tmp")
        if (tmpFile.exists()) {
            tmpFile.delete()
        }

        attachmentManager.streamAttachmentContent(attachment, { input ->
            tmpFile.withOutputStream { output ->
                byte[] buffer = new byte[8192]
                int bytesRead = input.read(buffer)
                while (bytesRead != -1) {
                    output.write(buffer, 0, bytesRead)
                    bytesRead = input.read(buffer)
                }
            }
            true
        } as InputStreamConsumer<Boolean>)

        if (!tmpFile.exists() || tmpFile.length() <= 0L) {
            return [file: null, error: (errors + "streamAttachmentContent bos dosya uretti").join(" | ")]
        }

        if (cacheFile.exists()) {
            cacheFile.delete()
        }
        if (!tmpFile.renameTo(cacheFile)) {
            cacheFile = tmpFile
        }
        cacheFile.deleteOnExit()
        return [file: cacheFile, error: ""]
    } catch (Exception ex) {
        errors << "streamAttachmentContent: ${ex.class.simpleName}: ${ex.message}"
    }

    [file: null, error: errors.findAll { it }.join(" | ")]
}

def navRangeFile = { File sourceFile, long start, long end, String filename ->
    def safeFilename = (filename ?: sourceFile.name ?: "asset.bin").replaceAll("[^A-Za-z0-9._-]", "_")
    def rangeDir = new File(System.getProperty("java.io.tmpdir"), "filozof-navigation-asset-ranges")
    if (!rangeDir.exists() && !rangeDir.mkdirs()) {
        throw new IOException("Range cache klasoru olusturulamadi: ${rangeDir.absolutePath}")
    }

    long contentLength = end - start + 1L
    def rangeFile = new File(rangeDir, "${sourceFile.name.hashCode()}-${sourceFile.length()}-${start}-${end}-${safeFilename}")
    if (rangeFile.exists() && rangeFile.length() == contentLength) {
        return rangeFile
    }

    def tmpFile = new File(rangeDir, "${rangeFile.name}.tmp")
    if (tmpFile.exists()) {
        tmpFile.delete()
    }

    byte[] buffer = new byte[8192]
    sourceFile.withInputStream { input ->
        long skipped = 0L
        while (skipped < start) {
            long skippedNow = input.skip(start - skipped)
            if (skippedNow <= 0L) {
                if (input.read() == -1) break
                skippedNow = 1L
            }
            skipped += skippedNow
        }

        tmpFile.withOutputStream { output ->
            long remaining = contentLength
            while (remaining > 0L) {
                int readSize = remaining > buffer.length ? buffer.length : remaining as int
                int bytesRead = input.read(buffer, 0, readSize)
                if (bytesRead == -1) break
                output.write(buffer, 0, bytesRead)
                remaining -= bytesRead
            }
        }
    }

    if (!tmpFile.exists() || tmpFile.length() <= 0L) {
        throw new IOException("Range dosyasi olusturulamadi: ${start}-${end}")
    }

    if (rangeFile.exists()) {
        rangeFile.delete()
    }
    if (!tmpFile.renameTo(rangeFile)) {
        rangeFile = tmpFile
    }
    rangeFile.deleteOnExit()
    rangeFile
}

