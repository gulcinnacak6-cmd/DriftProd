        jql = "project = HC AND ${driftIssueScopeJql} AND ${convertedRequestJql} ORDER BY created DESC"
    } else if (scope in ["bankcontrol", "minecontrol", "control"]) {
        jql = "project = HC AND ${driftIssueScopeJql} AND status = 'Olgunluk Kontrolü' ORDER BY created DESC"
    } else if (scope == "backlog") {
        jql = "project = HC AND ${driftIssueScopeJql} AND status = Backlog ORDER BY created DESC"
    } else if (scope in ["worklist", "islistesi"]) {
        jql = "project = HC AND ${driftIssueScopeJql} AND status = 'İş Listesi' ORDER BY created DESC"
