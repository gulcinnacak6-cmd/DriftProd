def scoreBusinessValue = { Map fieldDef, def rawValue, def issue = null ->
    def value = rawValue?.toString()?.trim()
    if (!value || value == "-") return null

    def numericMatcher = value =~ /^\s*([1-5])(?:\s*[-.)].*|\s*)$/
    if (numericMatcher.matches()) {
        return numericMatcher[0][1] as Integer
    }

    def normalizedValue = normalizeOptionText(stripBusinessScorePrefix(value))
    def options = getBusinessScoreFieldOptions(fieldDef, issue)
    Integer matchedIndex = null
    options.eachWithIndex { option, index ->
        if (matchedIndex != null) return
        def normalizedOption = normalizeOptionText(stripBusinessScorePrefix(option))
        if (normalizedValue == normalizedOption ||
            normalizedValue.endsWith(normalizedOption) ||
            normalizedOption.endsWith(normalizedValue)) {
            matchedIndex = index
        }
    }
    if (matchedIndex != null) return matchedIndex + 1

    if (normalizedValue.startsWith("cok yuksek")) return 5
    if (normalizedValue.startsWith("yuksek")) return 4
    if (normalizedValue.startsWith("orta")) return 3
    if (normalizedValue.startsWith("dusuk")) return 2
    if (normalizedValue.startsWith("yok") || normalizedValue.contains("etkisi yok")) return 1

    null
}

