def statusModeForAuth = { def issue ->
    def normalized = normalizeGroupName(issue?.status?.name ?: "")
    if (normalized.contains("olgunluk kontrol") || normalized.contains("olg. kont")) return "control"
    if (normalized.contains("olgunlastirma")) return "maturity"
    if (normalized.contains("onceliklendirme")) return "prioritization"
    if (normalized.contains("backlog") || normalized.contains("talebe donusturuldu")) return "backlog"
    if (normalized.contains("is list")) return "worklist"
    "readonly"
}

def authorizeOlgunlastirmaAction = { ApplicationUser user, def issue, String actionType, String editScope, Integer transitionId ->
    if (hasFullOlgunlastirmaAccess(user)) {
        return [success: true, fullAccess: true, scope: editScope ?: ""]
    }

    def normalizedAction = actionType?.toString()?.trim()?.toLowerCase(Locale.ENGLISH) ?: ""
    def normalizedScope = editScope?.toString()?.trim()?.toLowerCase(Locale.ENGLISH) ?: ""
    def mode = statusModeForAuth(issue)
    def hasAnaSorumluGroupAccess = userMatchesIssueGGroup(user, issue, CF_ANA_SORUMLU_GRUP)
    def requestedTransitionId = transitionId?.toString()?.trim()
    def expectedWorkflowTransitionId = null
    if (normalizedAction == "backlog") expectedWorkflowTransitionId = TRANSITION_IDS_BY_KEY.backlogAlindi?.toString()?.trim()
    if (normalizedAction == "worklist") expectedWorkflowTransitionId = TRANSITION_IDS_BY_KEY.isListesineAlindi?.toString()?.trim()

    if (expectedWorkflowTransitionId && requestedTransitionId == expectedWorkflowTransitionId && hasAnaSorumluGroupAccess) {
        return [success: true, fullAccess: false, scope: "workflow"]
    }

    if (transitionId != null || ["complete", "backlog", "worklist"].contains(normalizedAction)) {
        return [success: false, message: "Bu geçiş için Portföy Yönetimi Ofisi yetkisi gerekli."]
    }

    if (normalizedAction == "save" && mode == "maturity") {
        if (normalizedScope == "business" && userMatchesIssueGGroup(user, issue, CF_BUSINESS_AUTH_GROUP)) {
            return [success: true, fullAccess: false, scope: "business"]
        }
        if (normalizedScope == "it" && hasAnaSorumluGroupAccess) {
            return [success: true, fullAccess: false, scope: "it"]
        }
        return [success: false, message: "Bu kayıtta düzenleme için ilgili G grubu eşleşmiyor."]
    }

    [success: false, message: "Bu statüde düzenleme için Portföy Yönetimi Ofisi yetkisi gerekli."]
}

