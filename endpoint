def getCascadingFieldOptions = { def cf, def issue ->
    def allOptions = getCustomFieldOptions(cf, issue)
    def parents = allOptions.findAll { opt -> opt && !getOptionParent(opt) }

    parents.collect { parent ->
        def children = getOptionChildren(parent)
        if (!children) {
            children = allOptions.findAll { child ->
                def parentOption = getOptionParent(child)
                parentOption && parentOption.optionId == parent.optionId
            }
        }

        [
            value   : optionText(parent),
            label   : optionText(parent),
            children: children
                .findAll { child -> child && !child.disabled }
                .collect { child -> [value: optionText(child), label: optionText(child)] }
                .findAll { child -> child.value }
        ]
    }.findAll { parent -> parent.value }
}

def getCascadingSelectedValue = { def rawValue ->
    def parentOption = null
    def childOption = null

    if (rawValue instanceof Map) {
        parentOption = rawValue[null] ?: rawValue.get(null) ?: rawValue["null"] ?: rawValue.get("null")
        childOption = rawValue["1"] ?: rawValue.get("1") ?: rawValue[1] ?: rawValue.get(1)
    } else if (rawValue instanceof Option) {
        parentOption = rawValue
    }

    def parentText = optionText(parentOption)
    def childText = optionText(childOption)
    [
        parent : parentText,
        child  : childText,
        display: [parentText, childText].findAll { it }.join(" / ")
    ]
}

def setCascadingSelectField = { MutableIssue issue, String fieldId, String rawValue ->
    def cf = getCf(fieldId)
    if (!cf) return

    def parts = (rawValue ?: "").toString().split("\\|\\|", -1).collect { it.trim() }
    def parentValue = parts ? parts[0] : ""
    def childValue = parts.size() > 1 ? parts[1] : ""

    if (!parentValue) {
        issue.setCustomFieldValue(cf, null)
        return
    }

    def allOptions = getCustomFieldOptions(cf, issue)
    def parentOptions = allOptions.findAll { opt -> opt && !getOptionParent(opt) }
    def parentOption = findOptionByValue(parentOptions, parentValue) ?: findOptionByValue(allOptions, parentValue)

    if (!parentOption) {
        log.warn("Cascading parent option not found: ${fieldId} -> ${parentValue}")
        return
    }

    def childOption = null
    if (childValue) {
        def childOptions = getOptionChildren(parentOption)
        if (!childOptions) {
            childOptions = allOptions.findAll { child ->
                def parent = getOptionParent(child)
                parent && parent.optionId == parentOption.optionId
            }
        }
        childOption = findOptionByValue(childOptions, childValue)
        if (!childOption) {
            log.warn("Cascading child option not found: ${fieldId} -> ${parentValue} / ${childValue}")
        }
    }

    def cascadeValue = new LinkedHashMap()
    cascadeValue[null] = parentOption
    if (childOption) cascadeValue["1"] = childOption
    issue.setCustomFieldValue(cf, cascadeValue)
}

def setCustomFieldSmart = { MutableIssue issue, String fieldId, def rawValue ->
    def cf = getCf(fieldId)
    if (!cf) return

    String value = rawValue?.toString()?.trim()
    if (!value) {
        issue.setCustomFieldValue(cf, null)
        return
    }

    def typeKey = cf.customFieldType?.key?.toString()?.toLowerCase() ?: ""
    String typeName = cf.customFieldType?.class?.simpleName ?: ""
    if (typeKey.contains("cascadingselect")) {
        setCascadingSelectField(issue, fieldId, value)
        return
    }

    boolean isOptionField = typeKey.contains("select") ||
        typeKey.contains("radio") ||
        typeKey.contains("checkbox") ||
        fieldId == CF_DOMAIN_ADI_OPTIONS
    boolean isMulti = typeKey.contains("multiselect") ||
        typeKey.contains("multi") ||
        typeName.startsWith("Multi")
    def options = getCustomFieldOptions(cf, issue)

    if (options && !options.isEmpty()) {
        if (isMulti) {
            def selectedOptions = value.split(",")
                .collect { it.trim() }
                .findAll { it }
                .collect { v -> findOptionByFieldValue(options, fieldId, v) }
                .findAll { it }

            if (selectedOptions) {
                issue.setCustomFieldValue(cf, selectedOptions)
            } else {
                log.warn("Option field value not found: ${fieldId} -> ${value}; candidates=${candidateOptionValues(fieldId, value)}")
            }
        } else {
            def selected = findOptionByFieldValue(options, fieldId, value)
            if (selected) {
                issue.setCustomFieldValue(cf, selected)
            } else {
                log.warn("Option field value not found: ${fieldId} -> ${value}; candidates=${candidateOptionValues(fieldId, value)}")
            }
        }
        return
    }

    if (isOptionField) {
        log.warn("Option field update skipped because options could not be resolved: ${fieldId} -> ${value}")
        return
    }

    issue.setCustomFieldValue(cf, value)
}

def parsePaydasUnitNames = { def rawValue ->
    def text = rawValue?.toString()?.trim()
    if (!text || text == "-") return []

    text.split(/\s*;\s*/).collectMany { part ->
        def piece = part?.trim()
        if (!piece) {
            []
        } else {

            def marker = (piece =~ /(?iu)\s+-\s+G[öo]r[üu][şs](?:\s+Sahipleri)?\s*:/)
            if (marker.find()) {
                piece = piece.substring(0, marker.start()).trim()
            } else if (piece.contains(":")) {
                piece = piece.substring(0, piece.indexOf(":")).trim()
            }

            piece.split(/\s*,\s*/).collect { it?.trim() }.findAll { it }
        }
    }.unique()
}

