    technicalScore > 5G ? technicalScore.divide(20G, 2, RoundingMode.HALF_UP) : technicalScore
}

def quadrantDecision = { BigDecimal businessScore, BigDecimal technicalMatrixScore ->
    if (businessScore == null || technicalMatrixScore == null) return [quadrant: "", decision: ""]

    def highBusiness = businessScore >= 3.0G
    def highTechnical = technicalMatrixScore >= 3.0G
    if (highBusiness && highTechnical) {
        return [quadrant: "Yüksek Business Değer + Yüksek Teknik Uygulanabilirlik", decision: "Öncelikli / Quick Win"]
    }
    if (highBusiness && !highTechnical) {
        return [quadrant: "Yüksek Business Değer + Düşük Teknik Uygulanabilirlik", decision: "Stratejik / Fazlandırılacak iş"]
    }
    if (!highBusiness && highTechnical) {
        return [quadrant: "Düşük-Orta Business Değer + Yüksek Teknik Uygulanabilirlik", decision: "Kapasite varsa yapılabilir"]
    }
    [quadrant: "Düşük-Orta Business Değer + Düşük Teknik Uygulanabilirlik", decision: "Öncelik dışı / kapsam daraltılır"]
}

def normalizeBusinessFieldsByGroup = { Map businessFields ->
    def normalized = new LinkedHashMap(businessFields ?: [:])
    BUSINESS_SCORE_GROUPS.each { group ->
        def selectedFields = group.fields.findAll { fieldDef ->
            normalized[fieldDef.id]?.toString()?.trim()
        }
        if (selectedFields.size() > 1) {
            def keepId = selectedFields.first().id
            group.fields.each { fieldDef ->
                if (fieldDef.id != keepId) {
                    normalized[fieldDef.id] = ""
                }
            }
        }
    }
    normalized
}

def calculateBusinessScorePayload = { Map businessFields, def technicalScoreRaw, def issue = null ->
    def safeBusinessFields = normalizeBusinessFieldsByGroup(businessFields ?: [:])
    def groupScores = [:]
    def fieldScores = [:]
    BigDecimal total = 0G
    int answeredGroups = 0

    BUSINESS_SCORE_GROUPS.each { group ->
        def scores = []
        group.fields.each { fieldDef ->
            def value = safeBusinessFields[fieldDef.id]?.toString()
            def score = scoreBusinessValue(fieldDef, value, issue)
            if (score != null) {
                scores << score
                fieldScores[fieldDef.id] = [value: value, score: score]
            }
        }

        def groupScore = scores ? scores.max() as Integer : null
        groupScores[group.key] = groupScore
        if (groupScore != null) {
            answeredGroups += 1
            total += (groupScore as BigDecimal) * (group.weight as BigDecimal)
        }
    }

    BigDecimal businessScore = answeredGroups > 0 ? total : null
    BigDecimal technicalScore = parseScoreDecimal(technicalScoreRaw)
    BigDecimal technicalMatrixScore = normalizeTechnicalMatrixScore(technicalScore)
    def quadrant = quadrantDecision(businessScore, technicalMatrixScore)
    BigDecimal talepScore = businessScore != null && technicalScore != null ? businessScore * technicalScore : null

    [
        businessScore        : businessScore,
        businessScoreDisplay : formatScoreValue(businessScore),
        businessLevel        : businessScoreLevel(businessScore),
        technicalScore       : technicalScore,
        technicalScoreDisplay: formatScoreValue(technicalScore),
        technicalMatrixScore : technicalMatrixScore,
        technicalMatrixDisplay: formatScoreValue(technicalMatrixScore),
        technicalLevel       : technicalMatrixScore == null ? "" : (technicalMatrixScore >= 3.0G ? "Yüksek Teknik Uygulanabilirlik" : "Düşük Teknik Uygulanabilirlik"),
        talepScore           : talepScore,
        talepScoreDisplay    : formatScoreValue(talepScore),
        quadrant             : quadrant.quadrant,
        decision             : quadrant.decision,
        groupScores          : groupScores,
        fieldScores          : fieldScores,
        answeredGroups       : answeredGroups,
        weights              : BUSINESS_SCORE_GROUPS.collectEntries { group -> [(group.key): group.weight] }
    ]
}

def evaluationHasIt = { String value ->
    value in [EVAL_STATUS_IT, EVAL_STATUS_DONE]
}

def evaluationHasBusiness = { String value ->
    value in [EVAL_STATUS_BUSINESS, EVAL_STATUS_DONE]
}

def nextEvaluationStatus = { String currentValue, boolean markIt, boolean markBusiness ->
    boolean hasIt = evaluationHasIt(currentValue) || markIt
    boolean hasBusiness = evaluationHasBusiness(currentValue) || markBusiness
    if (hasIt && hasBusiness) return EVAL_STATUS_DONE
    if (hasIt) return EVAL_STATUS_IT
    if (hasBusiness) return EVAL_STATUS_BUSINESS
    return currentValue ?: ""
}

def stripDomainAsMarker = { def value ->
    (value ?: "").toString().replaceAll(/(?i)\s*\(AS\)\s*$/, "").trim()
}

def splitDriftDomainNames = { def value ->
    (value ?: "").toString()
        .split(/[,;|]/)
        .collect { stripDomainAsMarker(it) }
        .findAll { it }
}

def parseDomainEffortText = { def value ->
    def text = value?.toString()?.trim()
    if (!text || text == "-") return []

    def pieces = []
    text.split(/\r?\n|;/).each { part ->
        def cleaned = part?.toString()?.trim()
        if (cleaned) pieces << cleaned
    }

    pieces.collect { piece ->
        def parts = piece.split(/\s*:\s*/, 3).collect { it.trim() }
        if (parts.size() >= 3) {
            def rawDomain = parts[0]
            return [
                domain : stripDomainAsMarker(rawDomain),
                effort : parts[1] ?: "",
                note   : parts[2] ?: "",
                primary: rawDomain != stripDomainAsMarker(rawDomain)
            ]
        }

        def splitIdx = piece.lastIndexOf(" - ")
        if (splitIdx > -1) {
            def rawDomain = piece.substring(0, splitIdx).trim()
            return [
                domain : stripDomainAsMarker(rawDomain),
                effort : piece.substring(splitIdx + 3).trim(),
                note   : "",
                primary: rawDomain != stripDomainAsMarker(rawDomain)
            ]
        }

        [
            domain : stripDomainAsMarker(piece),
            effort : "",
            note   : "",
            primary: piece != stripDomainAsMarker(piece)
        ]
    }.findAll { it.domain }
}

def buildDomainEffortTextFromSources = { String primaryDomainRaw, String technicalStakeholdersRaw, String existingEffortRaw ->
    def primaryDomain = stripDomainAsMarker(primaryDomainRaw)
    def desiredDomains = []
    def addDomain = { def raw ->
        def domain = stripDomainAsMarker(raw)
        if (domain && !desiredDomains.contains(domain)) desiredDomains << domain
    }

    addDomain(primaryDomain)
    splitDriftDomainNames(technicalStakeholdersRaw).each { addDomain(it) }
    if (!desiredDomains) return ""

    def existingRows = parseDomainEffortText(existingEffortRaw)
    desiredDomains.collect { domain ->
        def existing = existingRows.find { row -> stripDomainAsMarker(row.domain) == domain }
        def label = primaryDomain && domain == primaryDomain ? "${domain} (AS)" : domain
        "${label} : ${existing?.effort ?: ""} : ${existing?.note ?: ""}"
    }.join("; ")
}

def affectedDomainLevelForCount = { int count ->
    if (count <= 0) return ""
    if (count == 1) return "Çok Düşük"
    if (count == 2) return "Düşük"
    if (count == 3) return "Orta"
    if (count == 4) return "Yüksek"
    "Çok Yüksek"
}

def affectedDomainLevelFromEffortText = { def effortText ->
    def domains = parseDomainEffortText(effortText)
        .collect { row -> stripDomainAsMarker(row.domain) }
        .findAll { it }
        .unique()
    affectedDomainLevelForCount(domains.size())
}

