def getFilozofExecutionUser = {
    def executionUser = userManager.getUserByKey(FILOZOF_EXECUTION_USER) ?: userManager.getUserByName(FILOZOF_EXECUTION_USER)
    if (!executionUser) {
        def currentUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
        if (currentUser) {
            log.warn("Filozof execution user bulunamadi: ${FILOZOF_EXECUTION_USER}. Request user ile devam ediliyor: ${currentUser.name ?: currentUser.key}")
            return currentUser
        }
        throw new IllegalStateException("Filozof execution user bulunamadi: ${FILOZOF_EXECUTION_USER}")
    }
    executionUser
}

def asFilozofExecutionUser = { Closure work ->
    def authContext = ComponentAccessor.jiraAuthenticationContext
    def originalUser = authContext.loggedInUser
    try {
        authContext.setLoggedInUser(getFilozofExecutionUser())
        return work()
    } finally {
        authContext.setLoggedInUser(originalUser)
    }
}

