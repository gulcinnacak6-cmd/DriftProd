/* =========================================================
   5) TRANSITION
   POST /rest/scriptrunner/latest/custom/transitionOlgunlastirma
   Body: {"key":"HC-123","transitionId":11}
         veya {"key":"HC-123","transitionKey":"olgunlukKontrolTamamlandi"}
   ========================================================= */

transitionOlgunlastirma(
    httpMethod: "POST"
) { MultivaluedMap qp, String body ->

    def requestData = new JsonSlurper().parseText(body ?: "{}")

    def issueKey = requestData.key?.toString()?.trim() ?: qp.getFirst("key")?.toString()?.trim()
    def transitionKeyRaw = requestData.transitionKey ?: qp.getFirst("transitionKey")
    def transitionIdRaw = resolveTransitionIdRaw(
        requestData.transitionId ?: qp.getFirst("transitionId"),
        transitionKeyRaw
    )

    if (!issueKey) {
        return Response.status(400)
            .entity(JsonOutput.toJson([success: false, message: "Issue Key alınamadı."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    if (!transitionIdRaw) {
        return Response.status(400)
            .entity(JsonOutput.toJson([success: false, message: "transitionId veya transitionKey zorunludur."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def transitionId = parseTransitionId(transitionIdRaw)
    if (transitionId == null) {
        return Response.status(400)
            .entity(JsonOutput.toJson([success: false, message: "Transition ID sayısal olmalıdır. endpoint.groovy içindeki TRANSITION_IDS_BY_KEY değerlerini güncelleyin."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def requestUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
    if (!requestUser) {
        return Response.status(401)
            .entity(JsonOutput.toJson([success: false, message: "Giris gerekli."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def executionUser = getFilozofExecutionUser()
    def issue = issueManager.getIssueObject(issueKey)

    if (!issue) {
        return Response.status(404)
            .entity(JsonOutput.toJson([success: false, message: "Kayıt bulunamadı."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def backlogWorklistTransitionIds = [
        TRANSITION_IDS_BY_KEY.backlogAlindi?.toString()?.trim(),
        TRANSITION_IDS_BY_KEY.isListesineAlindi?.toString()?.trim()
    ].findAll { it }
    def canRunBacklogWorklistTransition = backlogWorklistTransitionIds.contains(transitionIdRaw?.toString()?.trim()) &&
        userMatchesIssueGGroup(requestUser, issue, CF_ANA_SORUMLU_GRUP)

    if (!hasFullOlgunlastirmaAccess(requestUser) && !canRunBacklogWorklistTransition) {
        return Response.status(403)
            .entity(JsonOutput.toJson([success: false, message: "Bu geçiş için Portföy Yönetimi Ofisi yetkisi gerekli."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    try {
        def transitionResult = transitionIssue(executionUser, issue, transitionId)
        if (!transitionResult.success) {
            return Response.status(400)
                .entity(JsonOutput.toJson(transitionResult))
                .type(MediaType.APPLICATION_JSON)
                .build()
        }

        transitionResult.actedBy = [
            key        : requestUser?.key ?: "",
            name       : requestUser?.name ?: "",
            displayName: requestUser?.displayName ?: ""
        ]

        return Response.ok(JsonOutput.toJson(transitionResult))
            .type(MediaType.APPLICATION_JSON)
            .build()
    } catch (Exception e) {
        log.error("Transition Issue Error", e)
        return Response.status(500)
            .entity(JsonOutput.toJson([success: false, message: e.message]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }
}
/* =========================================================
   6) DOMAIN OPTIONS
   GET /rest/scriptrunner/latest/custom/fibarprDomainOptions
   customfield_10494 alaninin tum custom field option degerlerini dondurur
   ========================================================= */

fibarprDomainOptions(
    httpMethod: "GET"
) { MultivaluedMap qp ->

    def requestUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
    if (!requestUser) {
        return Response.status(401)
            .entity(JsonOutput.toJson([success: false, message: "Giris gerekli."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def cf = getCf(CF_DOMAIN_ADI_OPTIONS)
    if (!cf) {
        return Response.status(404)
            .entity(JsonOutput.toJson([success: false, message: "Domain option field bulunamadı."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def optionValues = []

    cf.configurationSchemes?.each { scheme ->
        scheme.configs?.values()?.each { config ->
            optionValues.addAll(optionsManager.getOptions(config) ?: [])
        }
    }

    def items = optionValues
        .findAll { it && !it.disabled }
        .collect { it.value?.toString()?.trim() }
        .findAll { it }
        .unique()
        .sort { it.toLowerCase() }
        .collect { [value: it, label: it] }

    return Response.ok(JsonOutput.toJson([items: items]))
        .type(MediaType.APPLICATION_JSON)
        .build()
}


/* =========================================================
   7) IDEA UNITS
   GET /rest/scriptrunner/latest/custom/fibarprIdeaUnits
   Olgunluk kontrol paydas secimi icin domain/birim listesini dondurur.
   ========================================================= */

fibarprIdeaUnits(
    httpMethod: "GET"
) { MultivaluedMap qp ->

    def requestUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
    if (!requestUser) {
        return Response.status(401)
            .entity(JsonOutput.toJson([success: false, message: "Giris gerekli."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    try {
        def cf = getCf(CF_DOMAIN_ADI_OPTIONS)
        if (!cf) {
            return Response.status(404)
                .entity(JsonOutput.toJson([success: false, message: "Birim/domain option field bulunamadi."]))
                .type(MediaType.APPLICATION_JSON)
                .build()
        }

        def optionValues = []

        cf.configurationSchemes?.each { scheme ->
            scheme.configs?.values()?.each { config ->
                optionValues.addAll(optionsManager.getOptions(config) ?: [])
            }
        }

        def items = optionValues
            .findAll { it && !it.disabled }
            .collect { it.value?.toString()?.trim() }
            .findAll { it }
            .unique()
            .sort { it.toLowerCase(new Locale("tr", "TR")) }
            .collect { [value: it, label: it] }

        return Response.ok(JsonOutput.toJson([items: items]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    } catch (Exception e) {
        log.error("Fibarpr idea units error", e)
        return Response.status(500)
            .entity(JsonOutput.toJson([success: false, message: "${e.class.simpleName}: ${e.message}".toString()]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }
}


/* =========================================================
   8) USER PICKER
   GET /rest/scriptrunner/latest/custom/userSearch?q=ali
   ========================================================= */

userSearch(
    httpMethod: "GET"
) { MultivaluedMap qp ->

    def requestUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
    if (!requestUser) {
        return Response.status(401)
            .entity(JsonOutput.toJson([success: false, message: "Giris gerekli."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def query = qp.getFirst("q")?.toString()?.toLowerCase()?.trim() ?: ""

    def users = userManager.getAllApplicationUsers()
        .findAll { it.displayName?.toLowerCase()?.contains(query) }
        .sort { it.displayName ?: "" }
        .take(20)

    def result = users.collect {
        [
            username   : it.key,
            displayName: it.displayName
        ]
    }

    return Response.ok(JsonOutput.toJson(result))
        .type(MediaType.APPLICATION_JSON)
        .build()
}

