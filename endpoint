def navAttachmentSummary = { attachments ->
    def names = (attachments ?: []).collect { attachment ->
        def name = navAttachmentName(attachment) ?: "(isimsiz)"
        def mimeType = navMimeType(name)
        mimeType ? "${name} [${mimeType}]" : name
    }
    if (!names) return "-"
    names.take(8).join(", ") + (names.size() > 8 ? ", ..." : "")
}

def navResolveAsset = { String type ->
    asFilozofExecutionUser {
        def expectedFilename = navAssetFileName(type)?.toString()?.trim()
        if (!expectedFilename) {
            return [success: false, status: 500, message: "Asset dosya adi tanimli degil. type=${type}"]
        }

        def issue = navAssetIssue()
        if (!issue) {
            return [success: false, status: 404, message: "Asset issue bulunamadi: ${NAV_ASSET_ISSUE_KEY}"]
        }

        def attachments = attachmentManager.getAttachments(issue) ?: []
        if (!attachments) {
            return [success: false, status: 404, message: "Asset issue attachment icermiyor: ${NAV_ASSET_ISSUE_KEY}"]
        }

        def attachment = attachments.find { navAttachmentName(it) == expectedFilename }
        if (!attachment) {
            return [success: false, status: 404, message: "Asset attachment bulunamadi. type=${type}, beklenen=${expectedFilename}, issue=${NAV_ASSET_ISSUE_KEY}, mevcut=${navAttachmentSummary(attachments)}"]
        }

        def fileResult = navAttachmentFile(attachment, expectedFilename)
        def file = fileResult.file
        if (!file) {
            return [success: false, status: 404, message: "Attachment file okunamadi. attachment=${expectedFilename}, detay=${fileResult.error ?: '-'}"]
        }

        if (!file.exists()) {
            return [success: false, status: 404, message: "Attachment file disk uzerinde bulunamadi. attachment=${expectedFilename}"]
        }

        long fileLength = file.length()
        if (fileLength <= 0L) {
            return [success: false, status: 404, message: "Attachment file bos. attachment=${expectedFilename}"]
        }

        [
            success : true,
            file    : file,
            filename: expectedFilename,
            mimeType: navMimeType(expectedFilename),
            length  : fileLength
        ]
    }
}

def getCf = { String id ->
    if (!id) return null

    if (!id.startsWith("REPLACE_")) {
        def byId = cfManager.getCustomFieldObject(id)
        if (byId) return byId
    }

    def fallbackNames = customFieldNameFallbacks[id] ?: []
    if (!fallbackNames) return null

    cfManager.getCustomFieldObjects()?.find { cf ->
        fallbackNames.any { expectedName ->
            cf?.name?.toString()?.equalsIgnoreCase(expectedName?.toString())
        }
    }
}

def getFieldValueAsString = { def issue, String fieldId ->
    try {
        def cf = getCf(fieldId)
        if (!cf) return "-"
        def val = issue.getCustomFieldValue(cf)
        if (val == null) return "-"
        if (val instanceof java.util.Date) return val.format("yyyy-MM-dd HH:mm")
        if (val instanceof ApplicationUser) return val.displayName ?: "-"
        if (val instanceof Option) return val.value ?: "-"
        if (val instanceof Collection) return val.collect { it instanceof Option ? it.value : it?.toString() }.findAll { it }.join(", ") ?: "-"
        if (fieldId == CF_PORTFOY_YONETICISI) {
            def portfoyUser = userManager.getUserByKey(val.toString()) ?: userManager.getUserByName(val.toString())
            if (portfoyUser) return portfoyUser.displayName ?: portfoyUser.key
        }
        return val.toString()
    } catch (Exception e) {
        log.warn("Custom field okunamadi. issue=${issue?.key}, field=${fieldId}, error=${e.class.simpleName}: ${e.message}")
        return "-"
    }
}

def getFieldValueOrBlank = { def issue, String fieldId ->
    def value = getFieldValueAsString(issue, fieldId)
    return value == "-" ? "" : value
}

def normalizeGroupName = { def value ->
    def text = value?.toString()?.trim()
    if (!text) return ""
    def normalized = java.text.Normalizer.normalize(
        text.toLowerCase(new Locale("tr", "TR")),
        java.text.Normalizer.Form.NFD
    )
    normalized.replaceAll("\\p{M}", "").replace("ı", "i")
}

def issueTypeNameOf = { def issue ->
    issue?.issueType?.name?.toString() ?: "-"
}

def issueStatusNameOf = { def issue ->
    issue?.status?.name?.toString() ?: "-"
}

def isIssueTypeIn = { def issue, Collection<String> typeNames ->
    def normalized = normalizeGroupName(issueTypeNameOf(issue))
    (typeNames ?: []).any { normalizeGroupName(it) == normalized }
}

def isDeliveryIssue = { def issue ->
    isIssueTypeIn(issue, ["Epic", "Teslimat"])
}

def issueInfoForTy = { def issue, String typeOverride = "" ->
    [
        key      : issue?.key ?: "-",
        issueType: typeOverride ?: issueTypeNameOf(issue),
        status   : issueStatusNameOf(issue)
    ]
}

def cleanIssueKey = { def raw ->
    def text = raw?.toString()?.trim()
    if (!text || text == "-") return ""
    def matcher = (text =~ /(?i)[A-Z][A-Z0-9]+-\d+/)
    matcher.find() ? matcher.group(0).toUpperCase(Locale.ENGLISH) : text
}

def issueByKey = { String issueKey ->
    if (!issueKey) return null
    def found = issueManager.getIssueObject(issueKey)
    if (found) return found
    try {
        return issueManager.getIssueByCurrentKey(issueKey)
    } catch (Exception ignored) {
        return null
    }
}

def linkedIssuesOf = { def sourceIssue ->
    if (!sourceIssue?.id) return []
    def linked = []

    try {
        issueLinkManager.getOutwardLinks(sourceIssue.id)?.each { link ->
            if (link?.destinationObject) linked << link.destinationObject
        }
    } catch (Exception ignored) {}

    try {
        issueLinkManager.getInwardLinks(sourceIssue.id)?.each { link ->
            if (link?.sourceObject) linked << link.sourceObject
        }
    } catch (Exception ignored) {}

    linked.findAll { it }.unique { it.key }
}

def epicChildrenFromJql = { def epicIssue ->
    if (!epicIssue?.key) return []
    try {
        def executionUser = getFilozofExecutionUser()
        def parseResult = jqlSearchService.parseQuery(executionUser, "\"Epic Link\" = ${epicIssue.key}")
        if (!parseResult?.valid) return []
        def results = jqlSearchService.search(executionUser, parseResult.query, PagerFilter.unlimitedFilter)
        return (results.results ?: []).findAll { it }
    } catch (Exception ignored) {
        return []
    }
}

def epicChildrenOf = { def epicIssue ->
    def children = []
    children.addAll(linkedIssuesOf(epicIssue))
    children.addAll(epicChildrenFromJql(epicIssue))
    children
        .findAll { child -> child?.key != epicIssue?.key && isIssueTypeIn(child, TY_EPIC_CHILD_ISSUE_TYPES) }
        .unique { it.key }
        .sort { a, b -> (a.key ?: "") <=> (b.key ?: "") }
}

def buildTyGeneralInfo = { def sourceIssue ->
    def tyKey = cleanIssueKey(getFieldValueOrBlank(sourceIssue, CF_TY_KEY))
    if (!tyKey) {
        return [
            tyKey          : "",
            message        : "TY kaydı bulunamadı.",
            deliveries     : [],
            standaloneTasks: []
        ]
    }

    def tyIssue = issueByKey(tyKey)
    if (!tyIssue) {
        return [
            tyKey          : tyKey,
            message        : "TY kaydı bulunamadı.",
            deliveries     : [],
            standaloneTasks: []
        ]
    }

    def directlyLinked = linkedIssuesOf(tyIssue)
    def deliveryIssues = directlyLinked
        .findAll { isDeliveryIssue(it) }
        .unique { it.key }
        .sort { a, b -> (a.key ?: "") <=> (b.key ?: "") }

    def deliveries = deliveryIssues.collect { delivery ->
        [
            issue   : issueInfoForTy(delivery, "Teslimat"),
            children: epicChildrenOf(delivery).collect { child -> issueInfoForTy(child) }
        ]
    }

    def deliveryChildKeys = deliveries.collectMany { block -> (block.children ?: []).collect { it.key } }.findAll { it } as Set
    def standaloneTasks = directlyLinked
        .findAll { linked -> isIssueTypeIn(linked, TY_STANDALONE_TASK_ISSUE_TYPES) && !deliveryChildKeys.contains(linked.key) }
        .unique { it.key }
        .sort { a, b -> (a.key ?: "") <=> (b.key ?: "") }
        .collect { task -> issueInfoForTy(task) }

    [
        tyKey          : tyKey,
        message        : deliveries ? "" : "Henüz Teslimat oluşturulmadı.",
        deliveries     : deliveries,
        standaloneTasks: standaloneTasks
    ]
}

