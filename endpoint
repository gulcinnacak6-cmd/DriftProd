/* =========================================================
   0) NAVIGATION ASSET API
   GET /rest/scriptrunner/latest/custom/navigationHubAsset?type=logo|video
   ========================================================= */

navigationHubAsset(httpMethod: "GET") { MultivaluedMap queryParams, String body, HttpServletRequest request ->

    def requestUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
    if (!requestUser) {
        return Response.status(401)
            .entity("Giris gerekli.")
            .type("text/plain; charset=UTF-8")
            .build()
    }

    def type = queryParams.getFirst("type")?.toString()?.trim()?.toLowerCase(Locale.ENGLISH)
    if (!(type in ["logo", "video"])) {
        return Response.status(400)
            .entity("type=logo veya type=video zorunludur.")
            .type("text/plain; charset=UTF-8")
            .build()
    }

    try {
        def asset = navResolveAsset(type)
        if (!asset.success) {
            return Response.status((asset.status ?: 500) as int)
                .entity(asset.message?.toString() ?: "Asset okunamadi.")
                .type("text/plain; charset=UTF-8")
                .build()
        }

        def file = asset.file
        def filename = asset.filename
        def safeFilename = filename.replaceAll("[\\r\\n\"]", "_")
        def mimeType = asset.mimeType
        long fileLength = asset.length as Long

        if (queryParams.getFirst("probe")?.toString()?.trim() == "1") {
            return Response.ok(JsonOutput.toJson([
                success : true,
                type    : type,
                filename: filename,
                mimeType: mimeType,
                length  : fileLength
            ]))
                .type(MediaType.APPLICATION_JSON)
                .header("Cache-Control", "private, max-age=60")
                .build()
        }

        def rangeHeader = request?.getHeader("Range")?.toString()
        if (rangeHeader?.startsWith("bytes=")) {
            long start = 0L
            long end = fileLength - 1L
            try {
                def rangeSpec = rangeHeader.substring(6).split(",", 2)[0].trim()
                def parts = rangeSpec.split("-", 2)
                if (parts[0]) {
                    start = Math.max(0L, parts[0] as Long)
                    if (parts.size() > 1 && parts[1]) {
                        end = Math.min(fileLength - 1L, parts[1] as Long)
                    }
                } else if (parts.size() > 1 && parts[1]) {
                    long suffixLength = Math.min(fileLength, parts[1] as Long)
                    start = fileLength - suffixLength
                    end = fileLength - 1L
                }
            } catch (Exception ignored) {
                start = 0L
                end = fileLength - 1L
            }

            if (start < 0L || start >= fileLength || end < start) {
                return Response.status(416)
                    .entity("Range gecersiz.")
                    .type("text/plain; charset=UTF-8")
                    .header("Content-Range", "bytes */${fileLength}")
                    .header("Accept-Ranges", "bytes")
                    .build()
            }

            def partialFile = (start == 0L && end == fileLength - 1L) ? file : navRangeFile(file, start, end, filename)
            long contentLength = end - start + 1L
            return Response.status(206)
                .entity(partialFile)
                .type(mimeType)
                .header("Content-Disposition", "inline; filename=\"${safeFilename}\"")
                .header("Content-Length", contentLength.toString())
                .header("Content-Range", "bytes ${start}-${end}/${fileLength}")
                .header("Accept-Ranges", "bytes")
                .header("Cache-Control", "private, max-age=3600")
                .build()
        }

        return Response.ok(file, mimeType)
            .header("Content-Disposition", "inline; filename=\"${safeFilename}\"")
            .header("Content-Length", fileLength.toString())
            .header("Accept-Ranges", "bytes")
            .header("Cache-Control", "private, max-age=3600")
            .build()
    } catch (Exception e) {
        log.error("Navigation asset okunamadi.", e)
        return Response.status(500)
            .entity("Asset okunamadi.")
            .type("text/plain; charset=UTF-8")
            .build()
    }
}

