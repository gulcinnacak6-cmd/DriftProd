def transitionIssue = { ApplicationUser user, def issue, Integer transitionId ->
    def issueService = ComponentAccessor.issueService
    def issueInputParameters = issueService.newIssueInputParameters()

    try {
        issueInputParameters.setSkipScreenCheck(true)
    } catch (MissingMethodException ignored) {
        try {
            issueInputParameters.skipScreenCheck()
        } catch (MissingMethodException ignoredAgain) {
            log.debug("IssueInputParameters skipScreenCheck metodu bulunamadı.")
        }
    }

    def validation = issueService.validateTransition(user, issue.id, transitionId, issueInputParameters)
    if (!validation?.valid) {
        return [
            success: false,
            message: errorCollectionToText(validation?.errorCollection)
        ]
    }

    def transitionResult = issueService.transition(user, validation)
    if (!transitionResult?.valid) {
        return [
            success: false,
            message: errorCollectionToText(transitionResult?.errorCollection)
        ]
    }

    return [
        success     : true,
        issueKey    : transitionResult.issue?.key ?: issue.key,
        transitionId: transitionId
    ]
}

