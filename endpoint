    def driftIssueScopeJql = "(issuetype = Fikir OR (issuetype = Talep AND cf[${sourceCustomId}] = \"Filozof\"))"
    def convertedRequestJql = "cf[${convertedRequestCustomId}] is not EMPTY"

    if (scope in ["all", "tumfikirler"]) {
        jql = "project = HC AND ${driftIssueScopeJql} ORDER BY created DESC"
    } else if (scope in ["myportfolio", "portfoyumdekitalep", "portfoyumdekitalepler"]) {
        jqlUser = requestUser
