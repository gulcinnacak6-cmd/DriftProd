def candidateOptionValues = { String fieldId, String value ->
    def candidates = []
    def addCandidate = { def candidate ->
        def text = candidate?.toString()?.trim()
        if (!text) return
        if (!candidates.any { normalizeOptionText(it) == normalizeOptionText(text) }) {
            candidates << text
        }
    }

    addCandidate(value)

    def aliases = itOptionAliasesByField[fieldId] ?: [:]
    aliases.each { alias, description ->
        if (normalizeOptionText(alias) == normalizeOptionText(value)) {
            addCandidate(description)
        }
        if (normalizeOptionText(description) == normalizeOptionText(value)) {
            addCandidate(alias)
        }
    }

    candidates
}

