        katilimciKullanicilar     : CF_KATILIMCI_KULLANICILAR,
        katilimciMailler          : CF_KATILIMCI_MAILLER
    ]

    def fieldsData = [:]

    fieldIds.each { k, id ->
        def cf = getCf(id)
        if (!cf) {
            fieldsData[k] = [value: "-", displayText: "-", options: [], users: []]
            return
        }

        def val = issue.getCustomFieldValue(cf)
        def typeKey = cf.customFieldType?.key?.toString()?.toLowerCase() ?: ""
        def options = getCustomFieldOptions(cf, issue)
            .collect { it.value?.toString() }
            .findAll { it }
        def cascadingOptions = typeKey.contains("cascadingselect") ? getCascadingFieldOptions(cf, issue) : []
        def cascadingValue = [parent: "", child: ""]

        def value = "-"
        def displayText = "-"
        def users = []

        if (val instanceof java.util.Date) {
            value = val.format("yyyy-MM-dd HH:mm")
            displayText = value
        } else if (val instanceof ApplicationUser) {
            value = val.key
            displayText = val.displayName ?: val.key
        } else if (val instanceof Option) {
            value = val.value ?: "-"
            displayText = value
        } else if (val instanceof Map) {
            cascadingValue = getCascadingSelectedValue(val)
            value = cascadingValue.display ?: "-"
            displayText = value
        } else if (val instanceof Collection) {
            if (val && val.every { it instanceof ApplicationUser }) {
                users = val.collect { u ->
                    [username: u.key, displayName: u.displayName ?: u.key]
                }
                value = users.collect { it.displayName }.join(", ")
                displayText = value
            } else {
                value = val.collect { it instanceof Option ? it.value : it?.toString() }.findAll { it }.join(", ") ?: "-"
                displayText = value
            }
        } else {
            value = val?.toString() ?: "-"
            displayText = value
            if (k == "portfoyYoneticisi" && value != "-") {
                def portfoyUser = userManager.getUserByKey(value) ?: userManager.getUserByName(value)
                if (portfoyUser) {
                    value = portfoyUser.key
                    displayText = portfoyUser.displayName ?: portfoyUser.key
                }
            }
        }

        fieldsData[k] = [
            value      : value,
            displayText: displayText,
            options    : options,
            cascadingOptions: cascadingOptions,
            cascadingValue: cascadingValue,
            users      : users,
            name       : k == "hcTalepTipi" ? "HC Talep Tipi" : cf.name,
            groupNames : groupNamesFromValue(val)
        ]
    }

    return Response.ok(JsonOutput.toJson([
        key        : issue.key,
        summary    : issue.summary ?: "-",
        description: issue.description ?: "-",
        status     : issue.status?.name ?: "-",
        reporter   : issue.reporter?.displayName ?: "-",
        created    : issue.created?.format("yyyy-MM-dd HH:mm"),
        updated    : issue.updated?.format("yyyy-MM-dd HH:mm"),
        tyGeneralInfo: buildTyGeneralInfo(issue),
        fields     : fieldsData
    ])).type(MediaType.APPLICATION_JSON).build()
}

/* =========================================================
   3) COMPLETE / SAVE
   POST /rest/scriptrunner/latest/custom/completeOlgunlastirma
   ========================================================= */

completeOlgunlastirma(
    httpMethod: "POST"
) { MultivaluedMap qp, String body ->

    def requestData = new JsonSlurper().parseText(body ?: "{}")

    def issueKey = requestData.key?.toString()
    def meetingDateStr = requestData.meetingDate?.toString()
    def paydaslar = requestData.paydaslar?.toString()
    def actionType = requestData.actionType?.toString()
    def editScope = requestData.editScope?.toString()?.trim()?.toLowerCase(Locale.ENGLISH) ?: ""
    def ideaFields = requestData.ideaFields instanceof Map ? requestData.ideaFields : [:]
    def itFields = requestData.itFields instanceof Map ? requestData.itFields : [:]
    def businessFields = normalizeBusinessFieldsByGroup(requestData.businessFields instanceof Map ? requestData.businessFields : [:])
    def priorityFields = requestData.priorityFields instanceof Map ? requestData.priorityFields : [:]
    def portfoyUser = requestData.portfoyUser?.toString()
    def participantUsers = requestData.participantUsers instanceof Collection ? requestData.participantUsers : []
    def participantMails = requestData.participantMails?.toString()
    def mailSubject = requestData.mailSubject?.toString()
    def mailContent = requestData.mailContent?.toString()
    def meetingLink = requestData.meetingLink?.toString()

    if (!issueKey) {
        return Response.status(400)
            .entity(JsonOutput.toJson([success: false, message: "Issue Key alınamadı."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def requestUser = ComponentAccessor.jiraAuthenticationContext.loggedInUser
    if (!requestUser) {
        return Response.status(401)
            .entity(JsonOutput.toJson([success: false, message: "Giris gerekli."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def executionUser = getFilozofExecutionUser()
    def mutable = issueManager.getIssueObject(issueKey) as MutableIssue

    if (!mutable) {
        return Response.status(404)
            .entity(JsonOutput.toJson([success: false, message: "Kayıt bulunamadı."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    def originalAnaSorumluBirim = getFieldValueOrBlank(mutable, CF_DOMAIN_ADI_OPTIONS)?.trim() ?: ""
    def originalTeknikPaydaslar = getFieldValueOrBlank(mutable, CF_TEKNIK_PAYDASLAR)?.trim() ?: ""
    def finalAnaSorumluBirim = originalAnaSorumluBirim
    def finalTeknikPaydaslar = originalTeknikPaydaslar

    def transitionKey = requestData.transitionKey?.toString()?.trim()
    def transitionIdRaw = resolveTransitionIdRaw(requestData.transitionId, transitionKey)
    Integer transitionId = null

    if (requestData.transitionId != null || transitionKey) {
        if (!transitionIdRaw) {
            return Response.status(400)
                .entity(JsonOutput.toJson([success: false, message: "Transition ID tanımlı değil."]))
                .type(MediaType.APPLICATION_JSON)
                .build()
        }

        transitionId = parseTransitionId(transitionIdRaw)
        if (transitionId == null) {
            return Response.status(400)
                .entity(JsonOutput.toJson([success: false, message: "Transition ID sayısal olmalıdır. endpoint.groovy içindeki TRANSITION_IDS_BY_KEY değerlerini güncelleyin."]))
                .type(MediaType.APPLICATION_JSON)
                .build()
        }
    }

    def authResult = authorizeOlgunlastirmaAction(requestUser, mutable, actionType, editScope, transitionId)
    if (!authResult.success) {
        return Response.status(403)
            .entity(JsonOutput.toJson([success: false, message: authResult.message ?: "Bu işlem için yetkiniz yok."]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }

    try {
        if (!authResult.fullAccess) {
            meetingDateStr = null
            paydaslar = null
            portfoyUser = null
            participantUsers = []
            participantMails = null
            mailSubject = null
            mailContent = null
            meetingLink = null

            if (authResult.scope == "workflow") {
                ideaFields = [:]
                itFields = [:]
                businessFields = [:]
                priorityFields = [:]
            } else if (authResult.scope == "business") {
                ideaFields = [:]
                itFields = [:]
                priorityFields = [:]
            } else if (authResult.scope == "it") {
                def requestedItScore = priorityFields.edit_priority_it_score?.toString()?.trim()
                ideaFields = [:]
                businessFields = [:]
                priorityFields = [:]

                if (requestedItScore) {
                    priorityFields.edit_priority_it_score = requestedItScore
                    def currentBusinessScore = parseScoreDecimal(getFieldValueOrBlank(mutable, CF_PRIORITY_BUSINESS_SCORE))
                    def newItScore = parseScoreDecimal(requestedItScore)
                    if (currentBusinessScore != null && newItScore != null) {
                        priorityFields.edit_priority_talep_skoru = formatScoreValue(currentBusinessScore * newItScore)
                    }
                }
            }
        }

        def payloadStatusMode = statusModeForAuth(mutable)
        def normalizedActionTypeForPayload = actionType?.toString()?.trim()?.toLowerCase(Locale.ENGLISH) ?: ""
        def allowItFieldPayload = payloadStatusMode == "maturity" && (normalizedActionTypeForPayload == "complete" || editScope == "it")
        def allowBusinessFieldPayload = payloadStatusMode == "maturity" && (normalizedActionTypeForPayload == "complete" || editScope == "business")
        def allowPriorityFieldPayload = payloadStatusMode == "prioritization" || allowItFieldPayload || allowBusinessFieldPayload

        if (!allowItFieldPayload) itFields = [:]
        if (!allowBusinessFieldPayload) businessFields = [:]
        if (!allowPriorityFieldPayload) priorityFields = [:]

        def currentEvaluationStatus = getFieldValueOrBlank(mutable, CF_DEGERLENDIRME_DURUMU)
        def marksItEvaluation = allowItFieldPayload && (normalizedActionTypeForPayload == "complete" || editScope == "it")
        def marksBusinessEvaluation = allowBusinessFieldPayload && (normalizedActionTypeForPayload == "complete" || editScope == "business")
        def effectiveEvaluationStatus = payloadStatusMode == "maturity"
            ? nextEvaluationStatus(currentEvaluationStatus, marksItEvaluation, marksBusinessEvaluation)
            : currentEvaluationStatus
        def canCalculateItScore = payloadStatusMode == "prioritization" || evaluationHasIt(effectiveEvaluationStatus)
        def canCalculateBusinessScore = payloadStatusMode == "prioritization" || evaluationHasBusiness(effectiveEvaluationStatus)

        if (allowItFieldPayload && !itFields.edit_it_etkilenen_domain?.toString()?.trim()) {
            def derivedAffectedDomain = affectedDomainLevelFromEffortText(
                itFields.edit_it_domain_efor ?: getFieldValueOrBlank(mutable, CF_IT_DOMAIN_EFOR_TEXT)
            )
            if (derivedAffectedDomain) {
                itFields = new LinkedHashMap(itFields)
                itFields.edit_it_etkilenen_domain = derivedAffectedDomain
            }
        }

        priorityFields = new LinkedHashMap(priorityFields)
        if (!canCalculateItScore) priorityFields.remove("edit_priority_it_score")
        if (!canCalculateBusinessScore) priorityFields.remove("edit_priority_business_score")
        if (!(canCalculateItScore && canCalculateBusinessScore)) priorityFields.remove("edit_priority_talep_skoru")

        def technicalScoreInput = canCalculateItScore ? (priorityFields.edit_priority_it_score ?: getFieldValueOrBlank(mutable, CF_PRIORITY_IT_SCORE)) : null
        def businessScoreResult = canCalculateBusinessScore ? calculateBusinessScorePayload(businessFields, technicalScoreInput, mutable) : [businessScore: null]
        if (businessScoreResult.businessScore != null) {
            priorityFields = new LinkedHashMap(priorityFields)
            priorityFields.edit_priority_business_score = businessScoreResult.businessScoreDisplay
            if (canCalculateItScore && businessScoreResult.talepScoreDisplay) {
                priorityFields.edit_priority_talep_skoru = businessScoreResult.talepScoreDisplay
            }
        }

        def fieldMap = [
            edit_portfoy_notu           : CF_PORTFOY_NOTU,
            edit_acil_talep_mi          : CF_ACIL_TALEP_MI,
            edit_hc_talep_tipi          : CF_HC_TALEP_TIPI,
            edit_amac                   : CF_AMAC,
            edit_problem                : CF_PROBLEM,
            edit_kpi                    : CF_KPI,
            edit_mevcut                 : CF_MEVCUT_DURUM,
            edit_cozum                  : CF_COZUM_TIPI,
            edit_hedef                  : CF_HEDEF_KITLE,
            edit_kanallar               : CF_ETKILENECEK_KANALLAR,
            edit_countly                : CF_COUNTLY_ENTEGRASYONU,
            edit_countly_desc           : CF_COUNTLY_ACIKLAMA,
            edit_nps                    : CF_NPS_TAKIP,
            edit_nps_desc               : CF_NPS_ACIKLAMA,
            edit_ui                     : CF_UI_ETKISI,
            edit_ui_desc                : CF_UI_ACIKLAMA,
            edit_dis                    : CF_DIS_SISTEM_ENTEGRASYONU,
            edit_rapor                  : CF_RAPORLAMA_ACIKLAMA,

            edit_it_tshirt_size          : CF_IT_TSHIRT_SIZE,
            edit_it_domain_efor          : CF_IT_DOMAIN_EFOR_TEXT,
            edit_it_domain_adi           : CF_DOMAIN_ADI_OPTIONS,
            edit_it_diger_domainler      : (CF_IT_DIGER_DOMAINLER != CF_TEKNIK_PAYDASLAR ? CF_IT_DIGER_DOMAINLER : null),
            edit_it_etkilenen_domain     : CF_IT_ETKILENEN_DOMAIN,
            edit_it_altyapi_etkisi       : CF_IT_ALTYAPI_ETKISI,
            edit_it_entegrasyon_etkisi   : CF_IT_ENTEGRASYON_ETKISI,
            edit_it_mevcut_sistem_etkisi : CF_IT_MEVCUT_SISTEM_ETKISI,
            edit_it_test_yayinlama       : CF_IT_TEST_YAYINLAMA,
            edit_it_dis_bagimlilik       : CF_IT_DIS_BAGIMLILIK,

            edit_bus_scope_growth_individual     : CF_BU_SCOPE_GROWTH_INDIVIDUAL,
            edit_bus_scope_growth_corporate      : CF_BU_SCOPE_GROWTH_CORPORATE,
            edit_bus_scope_operation             : CF_BU_SCOPE_OPERATION,
            edit_bus_operational_gain            : CF_BU_OPERATIONAL_GAIN,
            edit_bus_financial_growth_individual : CF_BU_FINANCIAL_GROWTH_INDIVIDUAL,
            edit_bus_financial_growth_corporate  : CF_BU_FINANCIAL_GROWTH_CORPORATE,
            edit_bus_customer_effect             : CF_BU_CUSTOMER_EFFECT,
            edit_bus_operational_fin_risk        : CF_BU_OPERATIONAL_FIN_RISK,

            edit_priority_business_score : CF_PRIORITY_BUSINESS_SCORE,
            edit_priority_it_score       : CF_PRIORITY_IT_SCORE,
            edit_priority_talep_skoru    : CF_TALEP_SKORU
        ]

        (ideaFields + itFields + businessFields + priorityFields).each { k, v ->
            def fieldId = fieldMap[k?.toString()]
            if (!fieldId) return
            try {
                setCustomFieldSmart(mutable, fieldId, v)
            } catch (Exception ex) {
                log.warn("Field update error: ${k} -> ${ex.message}")
            }
        }

        if (payloadStatusMode == "maturity" && effectiveEvaluationStatus && effectiveEvaluationStatus != currentEvaluationStatus) {
            try {
                setCustomFieldSmart(mutable, CF_DEGERLENDIRME_DURUMU, effectiveEvaluationStatus)
            } catch (Exception ex) {
                log.warn("Evaluation status update error: ${ex.message}")
            }
        }

        if (actionType == "complete") {
            def cfStatus = getCf(CF_OLGUNLASTIRMA_DURUMU)
            if (cfStatus) {
                def fieldConfig = cfStatus.getRelevantConfig(mutable)
                if (fieldConfig) {
                    def option = optionsManager.getOptions(fieldConfig)?.find {
                        it.value.equalsIgnoreCase("Olgunluk Toplantısı Planlandı") ||
                        it.value.equalsIgnoreCase("Olgunlaştırma Toplantısı Planlandı")
                    }
                    if (option) {
                        mutable.setCustomFieldValue(cfStatus, option)
                    }
                }
            }
        }

        if (meetingDateStr) {
            def cfDate = getCf(CF_MEETING_DATE)
            if (cfDate) {
                def date = new SimpleDateFormat("yyyy-MM-dd'T'HH:mm").parse(meetingDateStr)
                mutable.setCustomFieldValue(cfDate, new Timestamp(date.time))
            }
        }

        if (paydaslar != null) {
            setCustomFieldSmart(mutable, CF_ETKILENECEK_PAYDAS_ACIKLAMA, paydaslar)
            def etkilenecekPaydaslar = parsePaydasUnitNames(paydaslar).join(", ")
            setCustomFieldSmart(mutable, CF_ETKILENECEK_PAYDAS, etkilenecekPaydaslar)
        }

        if (ideaFields.containsKey("edit_control_domain_adi")) {
            def requestedAnaSorumluBirim = ideaFields.edit_control_domain_adi?.toString()?.trim() ?: ""
            finalAnaSorumluBirim = requestedAnaSorumluBirim
            if (requestedAnaSorumluBirim != originalAnaSorumluBirim) {
                setCustomFieldSmart(mutable, CF_DOMAIN_ADI_OPTIONS, requestedAnaSorumluBirim)
            }
        }

        if (ideaFields.containsKey("edit_control_teknik_paydaslar")) {
            def requestedTeknikPaydaslar = ideaFields.edit_control_teknik_paydaslar?.toString()?.trim() ?: ""
            finalTeknikPaydaslar = requestedTeknikPaydaslar
            if (requestedTeknikPaydaslar != originalTeknikPaydaslar) {
                setCustomFieldSmart(mutable, CF_TEKNIK_PAYDASLAR, requestedTeknikPaydaslar)
            }
        }

        if (ideaFields.containsKey("edit_control_domain_adi") || ideaFields.containsKey("edit_control_teknik_paydaslar")) {
            def currentDomainEffortText = getFieldValueOrBlank(mutable, CF_IT_DOMAIN_EFOR_TEXT)
            def refreshedDomainEffortText = buildDomainEffortTextFromSources(finalAnaSorumluBirim, finalTeknikPaydaslar, currentDomainEffortText)
            setCustomFieldSmart(mutable, CF_IT_DOMAIN_EFOR_TEXT, refreshedDomainEffortText)
        }

        if (portfoyUser != null) {
            setSingleUserPickerField(mutable, CF_PORTFOY_YONETICISI, portfoyUser)
        }

        if (requestData.containsKey("participantUsers") && !CF_KATILIMCI_KULLANICILAR.startsWith("REPLACE_")) {
            setMultiUserPickerField(mutable, CF_KATILIMCI_KULLANICILAR, participantUsers*.toString())
        }

        if (!CF_KATILIMCI_MAILLER.startsWith("REPLACE_") && participantMails != null) {
            setCustomFieldSmart(mutable, CF_KATILIMCI_MAILLER, participantMails)
        }

        if (requestData.containsKey("mailSubject")) {
            setCustomFieldSmart(mutable, CF_MAIL_SUBJECT, subjectWithIssueKey(issueKey, mailSubject))
        }

        if (requestData.containsKey("mailContent") || requestData.containsKey("meetingLink")) {
            setCustomFieldSmart(mutable, CF_MAIL_CONTENT, contentWithMeetingLink(mailContent, meetingLink))
        }

        issueManager.updateIssue(requestUser, mutable, EventDispatchOption.ISSUE_UPDATED, false)

        def transitionResult = null
        if (transitionId != null) {
            transitionResult = transitionIssue(executionUser, mutable, transitionId)
            if (!transitionResult.success) {
                return Response.status(400)
                    .entity(JsonOutput.toJson(transitionResult))
                    .type(MediaType.APPLICATION_JSON)
                    .build()
            }
        }

        return Response.ok(JsonOutput.toJson([
            success    : true,
            transitioned: transitionResult != null,
            transition : transitionResult,
            actedBy    : [
                key        : requestUser?.key ?: "",
                name       : requestUser?.name ?: "",
                displayName: requestUser?.displayName ?: ""
            ]
        ]))
            .type(MediaType.APPLICATION_JSON)
            .build()

    } catch (Exception e) {
        log.error("Update Issue Error", e)
        return Response.status(500)
            .entity(JsonOutput.toJson([success: false, message: e.message]))
            .type(MediaType.APPLICATION_JSON)
            .build()
    }
}

